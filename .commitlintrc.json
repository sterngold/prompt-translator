{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "refactor",
        "perf",
        "docs",
        "test",
        "chore",
        "ci",
        "build",
        "revert"
      ]
    ],
    "subject-case": [
      0
    ],
    "header-max-length": [
      2,
      "always",
      100
    ],
    "body-max-line-length": [
      0
    ],
    "footer-max-line-length": [
      0
    ]
  }
}